{
  "name": "naviris-browser",
  "productName": "Naviris",
  "version": "2.3.0",
  "description": "Naviris",
  "author": "Iris Studio",
  "license": "MIT",
  "main": "src/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/DosaAKA2A/Naviris.git"
  },
  "scripts": {
    "start": "electron .",
    "icon": "electron build/render-icon.js",
    "fetch-bin": "node build/fetch-bin.js",
    "dist": "electron-builder --win",
    "release": "electron-builder --win --publish always"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.estudiodeiris.cobalt",
    "productName": "Naviris",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "build/icon.png",
      "build/icon.ico",
      "!node_modules/adblock-rs/{target,src,benches,fuzz}/**",
      "!node_modules/adblock-rs/{Cargo.lock,Cargo.toml,rust-toolchain.toml,rustfmt.toml,CHANGELOG.md,README.md,SECURITY.md}"
    ],
    "electronLanguages": [
      "es",
      "es-419",
      "en-US"
    ],
    "icon": "build/icon.ico",
    "publish": {
      "provider": "github",
      "owner": "DosaAKA2A",
      "repo": "Naviris",
      "releaseType": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Naviris",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  },
  "dependencies": {
    "adblock-rs": "^0.13.2",
    "electron-updater": "^6.8.9"
  }
}

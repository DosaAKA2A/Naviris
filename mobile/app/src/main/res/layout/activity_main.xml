<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="@color/bg2"
        android:gravity="center_vertical"
        android:paddingHorizontal="6dp">

        <Button android:id="@+id/btnBack" style="?attr/borderlessButtonStyle"
            android:layout_width="40dp" android:layout_height="40dp"
            android:text="‹" android:textSize="24sp" android:textColor="@color/muted"
            android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:padding="0dp" />

        <Button android:id="@+id/btnFwd" style="?attr/borderlessButtonStyle"
            android:layout_width="40dp" android:layout_height="40dp"
            android:text="›" android:textSize="24sp" android:textColor="@color/muted"
            android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:padding="0dp" />

        <EditText android:id="@+id/urlBar"
            android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/urlbar_bg"
            android:paddingHorizontal="14dp"
            android:textColor="@color/text" android:textColorHint="#5C5E64"
            android:textSize="14sp" android:hint="Busca o escribe una dirección"
            android:inputType="textUri" android:imeOptions="actionGo"
            android:maxLines="1" android:singleLine="true"
            android:selectAllOnFocus="true" android:importantForAutofill="no" />

        <Button android:id="@+id/btnReload" style="?attr/borderlessButtonStyle"
            android:layout_width="40dp" android:layout_height="40dp"
            android:text="⟳" android:textSize="18sp" android:textColor="@color/muted"
            android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:padding="0dp" />

        <Button android:id="@+id/btnTabs" style="?attr/borderlessButtonStyle"
            android:layout_width="40dp" android:layout_height="40dp"
            android:text="1" android:textSize="14sp" android:textColor="@color/accent"
            android:background="@drawable/urlbar_bg"
            android:layout_marginEnd="2dp"
            android:minWidth="0dp" android:insetLeft="4dp" android:insetRight="4dp" android:insetTop="6dp" android:insetBottom="6dp" android:padding="0dp" />

        <Button android:id="@+id/btnMenu" style="?attr/borderlessButtonStyle"
            android:layout_width="40dp" android:layout_height="40dp"
            android:text="⋮" android:textSize="20sp" android:textColor="@color/muted"
            android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:padding="0dp" />
    </LinearLayout>

    <ProgressBar android:id="@+id/progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent" android:layout_height="2dp"
        android:progressTint="@color/accent" android:visibility="gone"
        android:max="100" />

    <LinearLayout android:id="@+id/findBar"
        android:layout_width="match_parent" android:layout_height="46dp"
        android:orientation="horizontal" android:background="@color/bg2"
        android:gravity="center_vertical" android:paddingHorizontal="6dp"
        android:visibility="gone">

        <EditText android:id="@+id/findInput"
            android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/urlbar_bg"
            android:paddingHorizontal="14dp"
            android:textColor="@color/text" android:textColorHint="#5C5E64"
            android:textSize="14sp" android:hint="Buscar en la página"
            android:inputType="text" android:imeOptions="actionSearch"
            android:maxLines="1" android:singleLine="true"
            android:importantForAutofill="no" />

        <TextView android:id="@+id/findCount"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="0/0" android:textSize="12sp" android:textColor="@color/muted"
            android:paddingHorizontal="6dp" />

        <Button android:id="@+id/findPrev" style="?attr/borderlessButtonStyle"
            android:layout_width="36dp" android:layout_height="36dp"
            android:text="∧" android:textSize="16sp" android:textColor="@color/muted"
            android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:padding="0dp" />

        <Button android:id="@+id/findNext" style="?attr/borderlessButtonStyle"
            android:layout_width="36dp" android:layout_height="36dp"
            android:text="∨" android:textSize="16sp" android:textColor="@color/muted"
            android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:padding="0dp" />

        <Button android:id="@+id/findClose" style="?attr/borderlessButtonStyle"
            android:layout_width="36dp" android:layout_height="36dp"
            android:text="✕" android:textSize="14sp" android:textColor="@color/muted"
            android:minWidth="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:insetTop="0dp" android:insetBottom="0dp" android:padding="0dp" />
    </LinearLayout>

    <FrameLayout android:id="@+id/webContainer"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />
</LinearLayout>
